# Copy to .env.local for local dev. Never commit secrets.

# FastAPI service URL (where /translate lives)
NEXT_PUBLIC_API_URL=http://localhost:8000

# PostHog telemetry — leave EMPTY to disable telemetry locally.
# Production gets these from Vercel env vars (see docs/SIGNUP.md S1-9).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
